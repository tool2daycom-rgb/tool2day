# Copy to .env.local and fill from Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# رابط الموقع لتسجيل الدخول OAuth (Google / Facebook / GitHub)
NEXT_PUBLIC_SITE_URL=https://www.tool2day.com

# تواصل معنا — إرسال إلى Gmail (مستحسن على Vercel)
# أنشئ App Password من حساب Google ثم ضعها هنا
CONTACT_TO=tool2day.com@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tool2day.com@gmail.com
SMTP_PASS=your_gmail_app_password
